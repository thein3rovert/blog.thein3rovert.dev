---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "What I'm focused on right now",
	title: "Now",
};

const lastUpdated = "March 8th, 2026";
---

<PageLayout meta={meta}>
	<h1 class="blinking-title mb-4">Now</h1>
	<p class="mb-8 text-base italic text-gray-500">What I'm up to recently</p>

	<ul class="mb-8 list-disc space-y-3 pl-5 text-base leading-relaxed">
		<li>Working on software development and infrastructure optimization</li>
		<li>Deep-diving into Nix flakes and NixOS for everything — devices, servers, websites</li>
		<li>Tinkering with my homelab setup</li>
		<li>Cycling when the weather permits</li>
		<li>Reading <!-- replace with current book --></li>
		<li>Exploring new keyboard layouts and builds</li>
	</ul>

	<p class="text-sm text-gray-500">
		Last updated: {lastUpdated}
	</p>

	<p class="mt-6 text-sm text-gray-500">
		This is a <a href="https://nownownow.com/about" class="cactus-link" target="_blank" rel="noreferrer">now page</a>. You should make one too.
	</p>
</PageLayout>
