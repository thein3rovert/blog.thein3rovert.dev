---
import { type CollectionEntry } from "astro:content";
import SocialList from "@/components/SocialList.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";
import BlogPostCard from "@/components/blog/BlogPostCard.astro";

// Posts
const MAX_POSTS = 10; // Changing the noof post in the frontend
const allPosts = await getAllPosts();
const allPostsByDate = allPosts
	.sort(collectionDateSort)
	.slice(0, MAX_POSTS) as CollectionEntry<"post">[];
---

<PageLayout meta={{ title: "Home" }}>
	<!-- Introduction Section -->
	<section class="mb-4">
		<h2 class="blinking-title mb-6">HI, I'M SAMAD.</h2>
		<p class="mb-4 text-base">
			Coder, cyclist, hiker, mini-PC enthusiast, soon-to-be long-haul homelaber, GNU/Linux guy, and
			mid-tier keyboard snob. I use Nix, btw.
		</p>
		<SocialList />
	</section>

	<!-- Journal Section -->
	<section aria-label="Journal">
		<h2 class="blinking-title mb-6">JOURNAL</h2>

		<!-- ASCII art: scales to fit any screen -->
		<div class="ascii-banner mb-6 font-mono">
			<pre
				class="no-border leading-tight whitespace-pre">
████████ ██   ██ ███████ ██ ███    ██ ██████  ██████   ██████  ██    ██ ███████ ██████  ████████
   ██    ██   ██ ██      ██ ████   ██      ██ ██   ██ ██    ██ ██    ██ ██      ██   ██    ██
   ██    ███████ █████   ██ ██ ██  ██  █████  ██████  ██    ██ ██    ██ █████   ██████     ██
   ██    ██   ██ ██      ██ ██  ██ ██      ██ ██   ██ ██    ██  ██  ██  ██      ██   ██    ██
   ██    ██   ██ ███████ ██ ██   ████ ██████  ██   ██  ██████    ████   ███████ ██   ██    ██
      </pre>
		</div>

		<div class="mb-4 text-base leading-relaxed">
			<pre
				class="no-border mb-4 text-left whitespace-pre-wrap">
"Our lives are so full of activity
and chatter it's difficult to find quite time...
Those are the moments that are the most creative
for me. The location is less important than
the choice to turn other things off.
Because I find that the quitest
times of my life speak
the loudest".
      </pre>
			<p class="text-sm text-gray-600 italic">- Quite, Susan Cain;</p>
		</div>
	</section>

	<!-- Blog Posts Section -->
	<!-- <section class="mt-16 px-1 sm:p-4">
    <h2 class="blinking-title mb-8">POSTS</h2>
    {allPostsByDate.map((post) => (
      <BlogPostCard post={post} />
    ))}
  </section> -->
</PageLayout>

<style>
	.ascii-banner {
		width: 100%;
		overflow: hidden;
	}
	.ascii-banner pre {
		font-size: 14px;
		display: inline-block;
		transform-origin: top left;
		/* Scale the pre to fit the container width */
		scale: var(--ascii-scale, 1);
	}
</style>

<script>
	function scaleAscii() {
		const banner = document.querySelector(".ascii-banner");
		const pre = banner?.querySelector("pre");
		if (!banner || !pre) return;

		// Reset scale to measure natural width
		pre.style.setProperty("--ascii-scale", "1");
		const naturalWidth = pre.scrollWidth;
		const containerWidth = banner.clientWidth;

		if (naturalWidth > containerWidth) {
			const scale = containerWidth / naturalWidth;
			banner.style.setProperty("height", pre.scrollHeight * scale + "px");
			pre.style.setProperty("--ascii-scale", String(scale));
		} else {
			banner.style.removeProperty("height");
			pre.style.setProperty("--ascii-scale", "1");
		}
	}

	scaleAscii();
	window.addEventListener("resize", scaleAscii);
	document.addEventListener("astro:page-load", scaleAscii);
</script>
